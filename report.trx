\title{EXPA: Multi-Stage Adversarial Patch Defense Through \\
Cascade Detection and Explainable AI Localization}

\author{\IEEEauthorblockN{Hussein Harissa}
\IEEEauthorblockA{\textit{Computer Science and Networks Department} \\
\textit{ENSTA Bretagne}\\
Brest, France \\
hussein.harissa@ensta-bretagne.fr}
